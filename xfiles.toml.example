# Xfiles Configuration
# Copy to xfiles.toml and customize

[hub]
bind_addr = "0.0.0.0:9999"
max_agents = 100
heartbeat_interval_secs = 30
probe_interval_secs = 30
database_url = "sqlite:xfiles.db"

default_model = "kimi-k2.6"

[model_aliases]
default = "kimi-k2.6"
# Add any model names you want rewritten to your default
gpt-4o = "kimi-k2.6"
gpt-4o-mini = "kimi-k2.6"

[auth]
# Uncomment to require Bearer token on proxy and admin endpoints
# api_key = "super-secret-key"
# Uncomment to require Bearer token for WebSocket agent connections
# agent_token = "agent-secret"

[rate_limit]
enabled = true
max_requests = 100
window_secs = 60

[quantum]
enabled = true
decoherence_rate = 0.05
exploration_rate = 0.15
entanglement_window = 10
min_samples_before_exploit = 5

[discovery]
# Auto-scan these ports for AI services
scan_ports = [3000, 8080, 7777, 8000, 11434, 9000]
scan_interval_secs = 60
# Enable Docker container discovery (requires Docker socket access)
docker_enabled = false

[[ai.endpoints]]
name = "routage"
url = "http://localhost:8080"
endpoint_type = "router"
weight = 1.0
tags = ["bandit", "multi-model"]

[[ai.endpoints]]
name = "merlin"
url = "http://localhost:7777"
endpoint_type = "router"
weight = 1.0
tags = ["rl", "multi-provider"]

[[ai.endpoints]]
name = "cowabungaai"
url = "http://localhost:8000"
endpoint_type = "inference"
weight = 0.8
tags = ["self-hosted", "air-gapped"]

[[ai.endpoints]]
name = "agent-memory"
url = "http://localhost:8000"
endpoint_type = "memory"
weight = 0.9
tags = ["redis", "vector"]

[[ai.endpoints]]
name = "ollama"
url = "http://localhost:11434"
endpoint_type = "inference"
weight = 0.7
tags = ["local", "gguf"]

[[plumber.rules]]
name = "route_to_ai"
pattern = "type:llm_request"
destination = "/ai/route"
priority = 100

[[plumber.rules]]
name = "route_mcp_calls"
pattern = "type:mcp_tool_call"
destination = "/ai/mcp"
priority = 90
[plumber.rules.header_match]
# Only match messages with this header set
tool = "search"

[[plumber.rules]]
name = "log_all"
pattern = "*"
destination = "/proc/log"
priority = 1
